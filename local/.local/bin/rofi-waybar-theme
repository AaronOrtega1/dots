#!/bin/bash

# =========================
# Config
# =========================

DEFAULT_THEME="catppuccin"

WAYBAR_DIR="$HOME/.config/waybar"
HYPR_DIR="$HOME/.config/hypr"
ROFI_DIR="$HOME/.config/rofi"

WAYBAR_THEMES="$WAYBAR_DIR/themes"
HYPR_THEMES="$HYPR_DIR/themes"
ROFI_THEMES="$ROFI_DIR/themes"

# =========================
# Theme Selector
# =========================

SELECTED=$(
    find "$WAYBAR_THEMES" -type f -name "*.css" \
    | xargs -n 1 basename \
    | sed 's/.css//' \
    | sort \
    | rofi -dmenu \
        -theme-str 'window {width: 20%;}' \
        -i \
        -p "󰔎 Themes"
)

[ -z "$SELECTED" ] && exit

# =========================
# Waybar Theme
# =========================

if [ -f "$WAYBAR_THEMES/$SELECTED.css" ]; then
    ln -sf "$WAYBAR_THEMES/$SELECTED.css" \
           "$WAYBAR_DIR/current-theme.css"
else
    ln -sf "$WAYBAR_THEMES/$DEFAULT_THEME.css" \
           "$WAYBAR_DIR/current-theme.css"
fi

# =========================
# Hyprland Theme
# =========================

if [ -f "$HYPR_THEMES/$SELECTED.conf" ]; then
    ln -sf "$HYPR_THEMES/$SELECTED.conf" \
           "$HYPR_DIR/current-theme.conf"
else
    ln -sf "$HYPR_THEMES/$DEFAULT_THEME.conf" \
           "$HYPR_DIR/current-theme.conf"
fi

# =========================
# Rofi Theme
# =========================

if [ -f "$ROFI_THEMES/$SELECTED.rasi" ]; then
    ln -sf "$ROFI_THEMES/$SELECTED.rasi" \
           "$ROFI_DIR/current-theme.rasi"
else
    ln -sf "$ROFI_THEMES/$DEFAULT_THEME.rasi" \
           "$ROFI_DIR/current-theme.rasi"
fi


# =========================
# Reload Apps
# =========================

hyprctl reload

bash ~/.config/waybar/scripts/restart-waybar.sh

notify-send "󰔎 Theme Changed" "$SELECTED"
