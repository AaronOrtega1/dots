#!/bin/bash

THEMES_DIR="$HOME/.config/waybar/themes"

SELECTED=$(
    find "$THEMES_DIR" -type f -name "*.css" \
    | xargs -n 1 basename \
    | sed 's/.css//' \
    | sort \
    | rofi -dmenu \
        -theme-str 'window {width: 20%;}' \
        -i \
        -p "󰔎 Themes"
)

[ -z "$SELECTED" ] && exit

ln -sf "$THEMES_DIR/$SELECTED.css" \
       "$HOME/.config/waybar/current-theme.css"

bash ~/.config/waybar/scripts/restart-waybar.sh
